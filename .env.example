# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=

# Tavily API key (used for web search) — get yours at https://app.tavily.com
TAVILY_API_KEY=

# Gmail address you're sending from (e.g. you@gmail.com)
GMAIL_USER=

# Gmail App Password (not your account password) — generate one at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# Set to "true" to preview emails without sending them; set to "false" (or remove) to send for real
DRY_RUN=true
